#!/usr/bin/env python3
"""
jterminal — browser-based terminal, deploy on Render.

Set TOKEN env variable in Render dashboard.
Open https://your-app.onrender.com → enter token → get a bash shell.
From there: ssh, scp, rsync to any machine on the internet.

Install: pip3 install aiohttp
"""

import asyncio, os, pty, struct, fcntl, termios, json, time, pathlib, uuid
from aiohttp import web, WSMsgType

TOKEN      = os.environ.get('TOKEN', '')
PORT       = int(os.environ.get('PORT', 8080))
UPLOAD_DIR = pathlib.Path('/tmp/jterm')
FILE_TTL   = 300  # 5 min — files older than this are wiped by cleanup task

