    // Ctrl+Shift+C = copy selection
    if (e.ctrlKey && e.shiftKey && e.key === 'C') {
      e.preventDefault();
      const sel = term.getSelection();
      if (sel) navigator.clipboard.writeText(sel).catch(() => {});
      return false;
