# ── Auth ──────────────────────────────────────────────────────────────────────

def auth(request):
    return request.rel_url.query.get('token') == TOKEN

# ── PTY helpers ───────────────────────────────────────────────────────────────

def set_winsize(fd, rows, cols):
    winsize = struct.pack('HHHH', rows, cols, 0, 0)
    fcntl.ioctl(fd, termios.TIOCSWINSZ, winsize)

# ── WebSocket terminal ────────────────────────────────────────────────────────

async def ws_handler(request):
    if not auth(request):
        return web.Response(status=401, text='Bad token\n')

    ws = web.WebSocketResponse(heartbeat=20)
    await ws.prepare(request)

    master_fd, slave_fd = pty.openpty()
    set_winsize(master_fd, 24, 80)

    import hashlib
    cid = request.rel_url.query.get('cid', request.remote or 'default')
    cid_hash = hashlib.sha256(cid.encode()).hexdigest()[:12]
    pathlib.Path('/tmp/jterm').mkdir(exist_ok=True)
    hist_file = f'/tmp/jterm/.history_{cid_hash}'
    env = {**os.environ, 'TERM': 'xterm-256color', 'HOME': '/root',
           'USER': 'root', 'SHELL': '/bin/bash',
           'HISTFILE': hist_file, 'HISTSIZE': '5000', 'HISTFILESIZE': '5000',
           'PROMPT_COMMAND': 'history -a'}
    proc = await asyncio.create_subprocess_exec(
        '/bin/bash', '--login',
        stdin=slave_fd, stdout=slave_fd, stderr=slave_fd,
        close_fds=True, env=env,
    )
    os.close(slave_fd)

    loop    = asyncio.get_event_loop()
    pty_q   = asyncio.Queue()

    def on_pty_readable():
        try:
            data = os.read(master_fd, 4096)
            pty_q.put_nowait(('data', data))
        except OSError:
            pty_q.put_nowait(('eof', None))
            loop.remove_reader(master_fd)

    loop.add_reader(master_fd, on_pty_readable)

    async def pty_to_ws():
        while True:
            kind, data = await pty_q.get()
            if kind == 'eof':
                break
            try:
                await ws.send_bytes(data)
            except Exception:
                break

    async def ws_to_pty():
        async for msg in ws:
            if msg.type == WSMsgType.TEXT:
                try:
                    d = json.loads(msg.data)
                    if d.get('type') == 'resize':
                        set_winsize(master_fd, d['rows'], d['cols'])
                except Exception:
                    pass
            elif msg.type == WSMsgType.BINARY:
                try:
                    os.write(master_fd, msg.data)
                except OSError:
                    break
            elif msg.type in (WSMsgType.CLOSED, WSMsgType.ERROR):
                break

    reader = asyncio.create_task(pty_to_ws())
    writer = asyncio.create_task(ws_to_pty())

    await asyncio.wait([reader, writer], return_when=asyncio.FIRST_COMPLETED)

    reader.cancel()
    writer.cancel()

    try: proc.kill()
    except ProcessLookupError: pass

    try: loop.remove_reader(master_fd)
    except Exception: pass

    try: os.close(master_fd)
    except OSError: pass

    wipe_uploads()
    return ws

# ── File endpoints ────────────────────────────────────────────────────────────

KEY_EXTS = {'.pem', '.key', '.rsa', '.ppk', '.pub', '.id_rsa', ''}

def wipe_uploads():
    if UPLOAD_DIR.exists():
        for f in UPLOAD_DIR.glob('*'):
            try: f.unlink()
            except: pass

async def upload_handler(request):
    if not auth(request):
        return web.Response(status=401)
    UPLOAD_DIR.mkdir(parents=True, exist_ok=True)
    data     = await request.post()
    file     = data['file']
    filename = pathlib.Path(file.filename).name  # strip path, keep name only
    dest     = UPLOAD_DIR / filename
    dest.write_bytes(file.file.read())
    is_key = dest.suffix in KEY_EXTS or 'key' in filename.lower() or 'id_rsa' in filename.lower()
    return web.json_response({'filename': filename, 'is_key': is_key})

async def download_handler(request):
    if not auth(request):
        return web.Response(status=401)
    filename = pathlib.Path(request.match_info['filename']).name
    path = UPLOAD_DIR / filename
    if not path.exists():
        return web.Response(status=404, text='Not found')
    return web.FileResponse(path, headers={
        'Content-Disposition': f'attachment; filename="{filename}"'
    })

async def files_handler(request):
    if not auth(request):
        return web.Response(status=401)
    if not UPLOAD_DIR.exists():
        return web.json_response([])
    return web.json_response([f.name for f in UPLOAD_DIR.glob('*') if f.is_file()])

# ── Static + health ───────────────────────────────────────────────────────────

async def index_handler(request):
    return web.Response(content_type='text/html', text=HTML)

async def health_handler(request):
    return web.json_response({'status': 'ok'})

# ── Background cleanup ────────────────────────────────────────────────────────

async def cleanup_task():
    while True:
        await asyncio.sleep(60)
        if UPLOAD_DIR.exists():
            now = time.time()
            for f in UPLOAD_DIR.glob('*'):
                try:
                    if now - f.stat().st_mtime > FILE_TTL:
                        f.unlink()
                except Exception:
                    pass

# ── Start ─────────────────────────────────────────────────────────────────────

async def start():
    if not TOKEN:
        print("[!] TOKEN env variable not set — set it in Render dashboard.")
        import sys; sys.exit(1)

    app = web.Application(client_max_size=100 * 1024 * 1024)
    app.router.add_get ('/',                   index_handler)
    app.router.add_get ('/ws',                 ws_handler)
    app.router.add_post('/upload',             upload_handler)
    app.router.add_get ('/download/{filename}', download_handler)
    app.router.add_get ('/files',              files_handler)
    app.router.add_get ('/_health',            health_handler)

    runner = web.AppRunner(app)
    await runner.setup()
    await web.TCPSite(runner, '0.0.0.0', PORT).start()

    print(f"[+] jterminal running on port {PORT}")
    asyncio.create_task(cleanup_task())
    await asyncio.Event().wait()

if __name__ == '__main__':
    try:
        asyncio.run(start())
    except KeyboardInterrupt:
        print('\n[*] Stopped.')
