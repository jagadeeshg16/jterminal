      const d = await r.json();
      term.write(`\r\n\x1b[32m[uploaded → /tmp/jterm/${d.filename}]\x1b[0m\r\n`);
      if (d.is_key) term.write(`\x1b[33m[hint: chmod 600 /tmp/jterm/${d.filename}]\x1b[0m\r\n`);
    }
  }
  refreshFiles();
}

